// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String     @id           // Clerk ID
  firstName      String
  lastName       String
  email          String     @unique
  imageUrl       String?
  preferences   String?    // JSON string: { "familiarity": "mainstream|discovery|mixed", "genres": ["Pop", "Rock"] }
  createdAt      DateTime   @default(now())
  playlists      Playlist[]
  sharedPlaylists SharedPlaylist[]
}

model Song {
  id        String   @id @default(cuid())
  title     String
  artist    String
  videoId   String
  thumbnail String?
  
  playlist  Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  playlistId String
}

model SharedSong {
  id        String   @id @default(cuid())
  title     String
  artist    String
  videoId   String
  thumbnail String?
  
  sharedPlaylist   SharedPlaylist @relation(fields: [sharedPlaylistId], references: [id], onDelete: Cascade)
  sharedPlaylistId String
}

model Playlist {
  id        String   @id @default(cuid())
  prompt    String
  title     String
  songs     Song[]
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@index([createdAt])
  @@index([userId])
}

model SharedPlaylist {
  id                String   @id @default(cuid())
  prompt            String
  title             String
  songs             SharedSong[]
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalCreatorId String
  originalPlaylistId String
  sharedByName      String?
  sharedAt          DateTime @default(now())
  
  @@index([userId])
  @@index([originalPlaylistId])
}